DATABASE_URL=file:./data/cpa-nexus.db
NEXT_PUBLIC_APP_NAME=CPA Nexus
PORT=9527
CPA_NEXUS_CONFIG=config.toml
# Docker image tag used by docker-compose.yml for build/push.
CPA_NEXUS_IMAGE=cpa-nexus:latest
# Optional overrides for [auth] in config.toml:
# CPA_NEXUS_ADMIN_PASSWORD=admin
# CPA_NEXUS_COOKIE_NAME=cpa_nexus_session
# CPA_NEXUS_SESSION_MAX_AGE_DAYS=7
